generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum LeadStatus {
  NOVO
  CONTATADO
  CONVERTIDO
  DESCARTADO
}

enum StatusPagamento {
  PENDENTE
  PAGO
}

model AssistenciaTecnicaLead {
  id                   String          @id @default(cuid())
  nome                 String
  whatsapp             String
  modeloDispositivo    String
  descricaoProblema    String          @db.Text
  status               LeadStatus      @default(NOVO)
  valorServico         Decimal?        @db.Decimal(10, 2)
  statusPagamento      StatusPagamento @default(PENDENTE)
  // LGPD — timestamp of the data subject's consent at submission time,
  // required by the form before it will submit. Kept as evidence. Nullable
  // because leads captured before this field existed have no recorded
  // consent — never backfilled with a fabricated timestamp.
  consentimentoDadosEm DateTime?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  laudos Laudo[]

  @@index([whatsapp])
  @@index([status])
  @@map("assistencia_tecnica_leads")
}

model EsteticaMotorLead {
  id                   String          @id @default(cuid())
  nome                 String
  whatsapp             String
  veiculo              String
  servicoDesejado      String          @db.Text
  status               LeadStatus      @default(NOVO)
  valorServico         Decimal?        @db.Decimal(10, 2)
  statusPagamento      StatusPagamento @default(PENDENTE)
  // LGPD — timestamp of the data subject's consent at submission time,
  // required by the form before it will submit. Kept as evidence. Nullable
  // because leads captured before this field existed have no recorded
  // consent — never backfilled with a fabricated timestamp.
  consentimentoDadosEm DateTime?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  laudos Laudo[]

  @@index([whatsapp])
  @@index([status])
  @@map("estetica_motor_leads")
}

// "Laudo Técnico" — an immutable entry-condition report issued at drop-off,
// denormalized from its source lead so it never changes even if the lead is
// later edited. This is the anti-fraud record shared with the client.
model Laudo {
  id                 String   @id @default(cuid())
  numero             Int      @unique @default(autoincrement())
  clienteNome        String
  clienteWhatsapp    String
  identificadorLabel String
  identificadorValor String
  itensChecklist     String[]
  observacoesEntrada String   @db.Text
  createdAt          DateTime @default(now())

  // Cascade: a laudo has no standalone meaning once its source lead (the
  // same data subject) is deleted for an LGPD request — both must go together.
  assistenciaLeadId String?
  assistenciaLead   AssistenciaTecnicaLead? @relation(fields: [assistenciaLeadId], references: [id], onDelete: Cascade)
  esteticaLeadId    String?
  esteticaLead      EsteticaMotorLead?      @relation(fields: [esteticaLeadId], references: [id], onDelete: Cascade)

  @@index([assistenciaLeadId])
  @@index([esteticaLeadId])
  @@map("laudos")
}

// One admin per deployment (this is a white-label, single-tenant instance).
// trialStartedAt is the anchor the billing gate computes "days remaining" from.
// trialDurationDays defaults to the standard 7 but can be overridden per admin
// (e.g. a promotional extended trial) without touching any other deployment.
model Admin {
  id                String   @id @default(cuid())
  email             String   @unique
  passwordHash      String
  createdAt         DateTime @default(now())
  trialStartedAt    DateTime @default(now())
  trialDurationDays Int      @default(7)

  subscription        Subscription?
  settings            Settings?
  passwordResetTokens PasswordResetToken[]

  @@map("admins")
}

// Self-service "forgot password" flow. Only the SHA-256 hash of the raw
// token is stored — the raw value only ever exists in the emailed link, so
// a database leak alone can't be used to reset anyone's password. Each
// token is single-use (usedAt) and short-lived (expiresAt).
model PasswordResetToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  adminId String
  admin   Admin  @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@map("password_reset_tokens")
}

enum MotorServiceMode {
  ESTETICA
  OFICINA
  AMBOS
}

// Owner-configurable settings for this deployment, filled in during the
// post-login onboarding step and editable afterward from
// /dashboard/configuracoes. motorServiceMode only applies to the "estetica"
// vertical (which vehicle services this business offers); checklistItems
// overrides the default suggestions in src/config/condition-checklist.ts for
// the laudo intake form once the owner has saved their own list.
model Settings {
  id               String            @id @default(cuid())
  motorServiceMode MotorServiceMode?
  checklistItems   String[]
  onboardingDone   Boolean           @default(false)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  adminId String @unique
  admin   Admin  @relation(fields: [adminId], references: [id])

  @@map("settings")
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
}

// One row per Admin (single-tenant deployment). Updated exclusively by the
// Asaas webhook receiver (src/app/api/webhooks/asaas/route.ts) — never
// written to from client-facing code.
model Subscription {
  id                  String             @id @default(cuid())
  status              SubscriptionStatus @default(TRIALING)
  asaasCustomerId     String?
  asaasSubscriptionId String?
  currentPeriodEnd    DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  adminId String @unique
  admin   Admin  @relation(fields: [adminId], references: [id])

  @@map("subscriptions")
}
