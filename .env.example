# Vertente white-label servida ao cliente final por esta implantação.
# Valores válidos: "assistencia" | "estetica". Obrigatória — a aplicação falha ao subir sem isso.
VERTENTE_ATIVA="assistencia"

# Banco relacional (Neon, Supabase, RDS, ou o docker-compose.yml local).
# DATABASE_URL: conexão pooled — usada pela aplicação em runtime.
# DIRECT_URL: conexão direta (sem pooler) — usada pelo Prisma Migrate.
# Em provedores sem pooler (ex.: docker-compose local), use o mesmo valor nas duas.
DATABASE_URL="postgresql://nexis:nexis@localhost:5432/nexis_drive"
DIRECT_URL="postgresql://nexis:nexis@localhost:5432/nexis_drive"

# Canal de e-mail (Resend). RESEND_API_KEY + LEAD_NOTIFICATION_EMAIL_FROM
# também são usados para enviar o e-mail de "esqueci minha senha" — sem eles,
# a notificação de novo lead por e-mail e a recuperação de senha ficam
# desativadas (o link de redefinição não é enviado).
# LEAD_NOTIFICATION_EMAIL_TO é usado só para notificação de novo lead.
RESEND_API_KEY=""
LEAD_NOTIFICATION_EMAIL_FROM=""
LEAD_NOTIFICATION_EMAIL_TO=""

# Canal de webhook genérico (Zapier, Make, n8n, gateway de WhatsApp Business API, etc.).
# Deixe em branco para desativar este canal.
LEAD_NOTIFICATION_WEBHOOK_URL=""
LEAD_NOTIFICATION_WEBHOOK_SECRET=""

# Assina o cookie de sessão do /dashboard (JWT). Gere um valor forte e único por ambiente,
# ex.: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=""

# Usados só por scripts/create-admin.ts para provisionar/atualizar a conta do dono do
# estabelecimento (rode: npx tsx scripts/create-admin.ts). Não são lidos em runtime.
ADMIN_EMAIL=""
ADMIN_PASSWORD=""

# Billing (Asaas). Em branco = painel roda apenas no trial de 7 dias.
# ASAAS_WEBHOOK_TOKEN: token compartilhado configurado no painel do Asaas; validado no
#   header "asaas-access-token" em /api/webhooks/asaas.
# ASAAS_CHECKOUT_URL: link de pagamento exibido na tela /assinatura.
ASAAS_WEBHOOK_TOKEN=""
ASAAS_CHECKOUT_URL=""
